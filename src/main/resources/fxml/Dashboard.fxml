<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sms.controller.DashboardController">
   <left>
      <VBox prefWidth="220.0" spacing="10.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="sidebar-header" text="SMS Menu">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="20.0" left="15.0" top="20.0" />
               </VBox.margin>
            </Label>
            <Button mnemonicParsing="false" prefWidth="200.0" styleClass="sidebar-button" text="Dashboard">
               <VBox.margin>
                  <Insets left="10.0" />
               </VBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#showAddStudentForm" prefWidth="200.0" styleClass="sidebar-button" text="Add Student">
               <VBox.margin>
                  <Insets left="10.0" />
               </VBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#handleUpdate" prefWidth="200.0" styleClass="sidebar-button" text="Update Selected">
               <VBox.margin>
                  <Insets left="10.0" />
               </VBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#handleDelete" prefWidth="200.0" styleClass="sidebar-button, btn-danger" text="Delete Selected">
               <VBox.margin>
                  <Insets left="10.0" />
               </VBox.margin>
            </Button>
            <VBox VBox.vgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleLogout" prefWidth="200.0" styleClass="sidebar-button" text="Logout">
               <VBox.margin>
                  <Insets bottom="20.0" left="10.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </left>
   <center>
      <VBox prefHeight="200.0" prefWidth="100.0" spacing="20.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
         </padding>
         <children>
            <Label styleClass="page-title" text="Dashboard">
               <font>
                  <Font name="System Bold" size="28.0" />
               </font>
            </Label>
            
            <HBox spacing="20.0">
               <children>
                  <VBox prefHeight="100.0" prefWidth="250.0" styleClass="stat-card">
                     <children>
                        <Label styleClass="stat-title" text="Total Students" />
                        <Label fx:id="totalStudentsLabel" styleClass="stat-value" text="0" />
                     </children>
                  </VBox>
                  <VBox prefHeight="100.0" prefWidth="250.0" styleClass="stat-card">
                     <children>
                        <Label styleClass="stat-title" text="Average Marks" />
                        <Label fx:id="avgMarksLabel" styleClass="stat-value" text="0.0" />
                     </children>
                  </VBox>
                  <VBox prefHeight="100.0" prefWidth="250.0" styleClass="stat-card">
                     <children>
                        <Label styleClass="stat-title" text="Highest Scorer" />
                        <Label fx:id="topScorerLabel" styleClass="stat-value" text="N/A" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <TextField fx:id="searchField" prefWidth="400.0" promptText="Search by ID, Name or Course..." styleClass="search-field" />
                  <Button mnemonicParsing="false" styleClass="secondary-button" text="Search" />
               </children>
            </HBox>

            <TableView fx:id="studentTable" prefHeight="400.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="100.0" text="Student ID" />
                <TableColumn fx:id="colName" prefWidth="150.0" text="Name" />
                  <TableColumn fx:id="colCourse" prefWidth="120.0" text="Course" />
                  <TableColumn fx:id="colSemester" prefWidth="80.0" text="Semester" />
                  <TableColumn fx:id="colAge" prefWidth="60.0" text="Age" />
                  <TableColumn fx:id="colGender" prefWidth="80.0" text="Gender" />
                  <TableColumn fx:id="colMarks" prefWidth="90.0" text="Marks" />
                  <TableColumn fx:id="colPhone" prefWidth="120.0" text="Phone" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </center>
</BorderPane>
