<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="400.0" spacing="15.0" styleClass="login-container" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sms.controller.LoginController">
   <children>
      <Label styleClass="header-label" text="Student Management System">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <Label text="Please Login to Continue" textFill="#666666" />
      <VBox prefWidth="100.0" spacing="5.0">
         <children>
            <Label text="Username:" />
            <TextField fx:id="usernameField" promptText="Enter username..." styleClass="input-field" />
         </children>
         <VBox.margin>
            <Insets left="40.0" right="40.0" top="20.0" />
         </VBox.margin>
      </VBox>
      <VBox prefWidth="100.0" spacing="5.0">
         <children>
            <Label text="Password:" />
            <PasswordField fx:id="passwordField" promptText="Enter password..." styleClass="input-field" />
         </children>
         <VBox.margin>
            <Insets left="40.0" right="40.0" />
         </VBox.margin>
      </VBox>
      <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" prefWidth="320.0" styleClass="primary-button" text="Login">
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Button>
      <Label fx:id="errorLabel" textFill="#e74c3c">
         <font>
            <Font size="13.0" />
         </font>
      </Label>
   </children>
</VBox>
